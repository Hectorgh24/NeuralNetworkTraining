# ============================================================================
# TensorFlow Neural Network Training - .gitignore Configuration
# ============================================================================

# Python and packaging
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# IDE and editor configurations
.vscode/
.idea/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================================================
# Data and Datasets (Local Only - Not Committed to Git)
# ============================================================================

# Complete data directory
# Preserve locally: data/raw/, data/raw_float64_original/, data/processed/
# Users must generate these locally from source datasets using conversion scripts
data/

# Historical datasets reference (not needed for personal training)
data/UniMiB-SHAR/

# Dataset file formats
# Keep files locally for training, regenerate using:
# - convert_mat_to_npz.py       (MAT format to NumPy)
# - convert_to_float32.py        (float64 to float32 optimization)
*.mat
*.npz

# ============================================================================
# Model Artifacts and Training Outputs
# ============================================================================

# TensorFlow/Keras model files (generated during training)
.keras/
*.h5
*.hdf5
*.pb
*.ckpt*
*.pth

# Trained model weights and checkpoints
models/
checkpoints/
weights/
*.weights
saved_models/

# Training logs and metrics
logs/
runs/
*.log
.wandb/
tensorboard_logs/

# ============================================================================
# Large Data Files
# ============================================================================

# Tabular and structured data
*.csv
*.xlsx
*.json

# ============================================================================
# Temporary and Cache Files
# ============================================================================

*.tmp
*.temp
*.bak

# ============================================================================
# Secrets and Configuration
# ============================================================================

# Environment variables and secrets (NEVER commit)
.env
.env.local
.env.*.local

# ============================================================================
# Repository Contents (What Should Be Committed)
# ============================================================================
#
# ✓ Source code:
#   - src/*.py (training scripts, models, utilities)
#   - convert_mat_to_npz.py (dataset format conversion)
#   - convert_to_float32.py (dataset optimization)
#
# ✓ Configuration:
#   - requirements.txt (Python dependencies)
#   - README.md (project documentation)
#   - config.yaml or similar (hyperparameters, settings)
#
# ✓ Data structure (directories only, files ignored):
#   - data/raw/ (source datasets - .npz files generated locally)
#   - data/processed/ (processed datasets - generated locally)
#   - data/raw_float64_original/ (backup datasets - generated locally)
#
# ============================================================================
